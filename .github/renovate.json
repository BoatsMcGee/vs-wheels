{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "cloneSubmodules": true,
  "extends": [
    "config:best-practices",
    ":automergeMinor",
    ":automergePr",
    ":automergeRequireAllStatusChecks",
    ":disableDependencyDashboard",
    ":disableRateLimiting",
    ":semanticCommits",
    ":semanticCommitScopeDisabled",
    ":semanticCommitTypeAll(deps)"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/pkg-.*\\.yml$/"],
      "matchStrings": [
        "(?:default:|\\|\\|)\\s+['\"](?<currentValue>[^'\"]+)['\"].*?# renovate: datasource=(?<datasource>[a-z-\\.]+) depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?"
      ]
    }
  ],
  "customDatasources": {
    "vulkan-sdk-windows": {
      "defaultRegistryUrlTemplate": "https://vulkan.lunarg.com/sdk/latest.json",
      "format": "json",
      "transformTemplates": ["{\"releases\": [{\"version\": $.windows}]}"]
    },
    "vulkan-sdk-linux": {
      "defaultRegistryUrlTemplate": "https://vulkan.lunarg.com/sdk/latest.json",
      "format": "json",
      "transformTemplates": ["{\"releases\": [{\"version\": $.linux}]}"]
    },
    "vulkan-sdk-mac": {
      "defaultRegistryUrlTemplate": "https://vulkan.lunarg.com/sdk/latest.json",
      "format": "json",
      "transformTemplates": ["{\"releases\": [{\"version\": $.mac}]}"]
    },
    "rocm-linux": {
      "defaultRegistryUrlTemplate": "https://repo.radeon.com/rocm/el8/",
      "format": "html",
      "transformTemplates": [
        "{\"releases\": releases[version ~> /^[0-9]+(\\\\.[0-9]+)*\\\\/?$/].{ \"version\": $replace(version, \"/\", \"\") }}"
      ]
    }
  },
  "git-submodules": {
    "enabled": true
  },
  "ignoreDeps": [
    "bm3dcuda/bm3dcpu/vapoursynth",
    "bm3dcuda/bm3dcuda/vapoursynth",
    "bm3dcuda/bm3dhip/vapoursynth",
    "dfttest2/dfttest2_cpu/vapoursynth",
    "dfttest2/dfttest2_cuda/vapoursynth",
    "dfttest2/dfttest2_gcc/vapoursynth",
    "dfttest2/dfttest2_hip/vapoursynth",
    "dfttest2/dfttest2_hiprtc/vapoursynth",
    "dfttest2/dfttest2_nvrtc/vapoursynth",
    "vsmlrt/ncnn/vapoursynth",
    "vsmlrt/ort/vapoursynth",
    "vsmlrt/ov/vapoursynth",
    "vsmlrt/trt/vapoursynth",
    "vsmlrt/trt_rtx/vapoursynth",
    "vsmlrt/migx/vapoursynth"
  ],
  "packageRules": [
    {
      "extends": [":semanticCommitTypeAll(ci)"],
      "matchManagers": ["github-actions"]
    },
    {
      "automerge": true,
      "matchUpdateTypes": ["pin", "digest", "pinDigest"]
    },
    {
      "matchManagers": ["git-submodules"],
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["quay.io/pypa/manylinux_2_28_x86_64"],
      "enabled": false
    },
    {
      "matchManagers": ["custom.regex"],
      "automerge": false
    }
  ]
}
